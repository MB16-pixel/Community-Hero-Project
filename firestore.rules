rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive validation helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Entity Validation Helper
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.username is string && data.username.size() >= 2 && data.username.size() <= 100
        && data.email is string && data.email.size() <= 100
        && (!('password' in data) || (data.password is string && data.password.size() >= 4 && data.password.size() <= 100))
        && (!('xp' in data) || (data.xp is int || data.xp is number))
        && (!('community' in data) || (data.community is string && data.community.size() <= 100));
    }

    // Issue Entity Validation Helper
    function isValidIssue(data) {
      return data.issueId is string && data.issueId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.description is string && data.description.size() >= 3 && data.description.size() <= 1000
        && data.address is string && data.address.size() >= 3 && data.address.size() <= 500
        && data.mediaUrl is string && data.mediaUrl.size() <= 2000
        && data.category is string && data.category.size() <= 100
        && data.status is string && (data.status == 'Pending' || data.status == 'Verified' || data.status == 'Resolved')
        && (data.timestamp is string || data.timestamp is timestamp)
        && (!('reporterName' in data) || (data.reporterName is string && data.reporterName.size() <= 100));
    }

    // Budget Allocation Entity Validation Helper
    function isValidBudgetAllocation(data) {
      return data.allocationId is string && data.allocationId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.username is string && data.username.size() <= 100
        && data.country is string && data.country.size() <= 100
        && (data.riskReduction is int || data.riskReduction is number)
        && (data.thermalInsulationBudget is int || data.thermalInsulationBudget is number)
        && (data.acousticSensorsBudget is int || data.acousticSensorsBudget is number)
        && (data.pipeReplacementBudget is int || data.pipeReplacementBudget is number)
        && (data.emergencyBudget is int || data.emergencyBudget is number)
        && data.timestamp is string;
    }

    // Rules for Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isValidId(userId) && isValidUser(incoming());
      allow update: if isValidId(userId) && isValidUser(incoming());
      allow delete: if isValidId(userId); // destructive delete profile action
    }

    // Rules for Issues collection
    match /issues/{issueId} {
      allow read: if true;
      allow create: if isValidId(issueId) && isValidIssue(incoming());
      allow update: if isValidId(issueId) && isValidIssue(incoming());
      allow delete: if false; // Issues are archival
    }

    // Rules for Budget Allocations
    match /budget_allocations/{allocationId} {
      allow read: if true;
      allow create: if isValidId(allocationId) && isValidBudgetAllocation(incoming());
      allow update: if false; // Allocations are immutable historical logs
      allow delete: if false;
    }
  }
}
